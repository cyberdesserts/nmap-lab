{
    "name": "nmap-lab",
    "dockerComposeFile": "docker-compose.yml",
    "service": "workspace",
    "workspaceFolder": "/workspaces/nmap-lab",

    // Pin the smallest (2-core) machine. On the free tier this matters: compute
    // is billed in core-hours (cores x runtime), and the 120 core-hour monthly
    // allowance is 60 real hours on a 2-core box but only 30 on a 4-core one.
    // This lab does not need more than 2 cores. Requesting the smallest machine
    // here doubles the reader's effective free runtime.
    "hostRequirements": {
        "cpus": 2,
        "memory": "4gb",
        "storage": "32gb"
    },

    // The targets come up alongside the workspace via docker-compose. You reach
    // them by hostname (leaky-web, legacy-api, login-portal, multi-service) on
    // the internal labnet network. Nothing is forwarded to your local machine,
    // because the whole point is to scan inside the sealed lab network.
    "forwardPorts": [],

    "customizations": {
        "vscode": {
            "extensions": [],
            // Open the README (rendered) automatically when the Codespace opens, so a
            // newcomer lands on instructions instead of an empty editor. The README
            // points them straight to walkthrough/README.md.
            "settings": {
                "workbench.startupEditor": "readme"
            }
        }
    },

    // Wire the getting-started greeting into the interactive shell so the reader
    // actually SEES it. postCreateCommand output only lands in the creation log, not
    // the terminal you open afterwards, so instead we run welcome.sh once from
    // ~/.bashrc: the first terminal you open shows it, and a flag file stops it
    // repeating in later terminals.
    "postCreateCommand": "chmod +x .devcontainer/welcome.sh && grep -q nmaplab-welcome ~/.bashrc 2>/dev/null || printf '\\n# nmaplab-welcome: show the getting-started greeting once per codespace\\nif [ ! -f ~/.nmaplab_welcomed ]; then touch ~/.nmaplab_welcomed; bash /workspaces/nmap-lab/.devcontainer/welcome.sh; fi\\n' >> ~/.bashrc",

    // Run as the non-root analyst user. Note: unprivileged scans default to TCP
    // connect (-sT) rather than SYN (-sS). That is intentional and is taught in
    // the walkthrough.
    "remoteUser": "analyst"
}
