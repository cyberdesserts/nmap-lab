{
    "name": "nmap-lab",
    "dockerComposeFile": "docker-compose.yml",
    "service": "workspace",
    "workspaceFolder": "/workspaces/nmap-lab",

    // Pin the smallest (2-core) machine. On the free tier this matters: compute
    // is billed in core-hours (cores x runtime), and the 120 core-hour monthly
    // allowance is 60 real hours on a 2-core box but only 30 on a 4-core one.
    // This lab does not need more than 2 cores. Requesting the smallest machine
    // here doubles the reader's effective free runtime.
    "hostRequirements": {
        "cpus": 2,
        "memory": "4gb",
        "storage": "32gb"
    },

    // The targets come up alongside the workspace via docker-compose. You reach
    // them by hostname (leaky-web, legacy-api, login-portal, multi-service) on
    // the internal labnet network. Nothing is forwarded to your local machine,
    // because the whole point is to scan inside the sealed lab network.
    "forwardPorts": [],

    "customizations": {
        "vscode": {
            "extensions": []
        }
    },

    // Greet the reader and open the walkthrough. postCreateCommand output only reaches
    // the Codespace creation log, never the terminal, so the greeting is wired into
    // ~/.bashrc: it guards on TERM_PROGRAM=vscode so it fires in a real VS Code terminal
    // but NOT during the dev container's login-shell env probe (which sources ~/.bashrc
    // during setup and would otherwise consume the once-only flag before the reader sees
    // it), and it runs once per codespace. welcome.sh prints the greeting AND opens
    // walkthrough/README.md via the `code` CLI -- reliable because it runs inside the
    // VS Code terminal session, which postAttachCommand's context cannot reach.
    "postCreateCommand": "chmod +x .devcontainer/welcome.sh && grep -q nmaplab-welcome ~/.bashrc 2>/dev/null || printf '\\n# nmaplab-welcome: greet once in a real VS Code terminal (not the env probe)\\nif [ \"$TERM_PROGRAM\" = vscode ] && [ ! -f ~/.nmaplab_welcomed ]; then touch ~/.nmaplab_welcomed; bash /workspaces/nmap-lab/.devcontainer/welcome.sh; fi\\n' >> ~/.bashrc",

    // Run as the non-root analyst user. Note: unprivileged scans default to TCP
    // connect (-sT) rather than SYN (-sS). That is intentional and is taught in
    // the walkthrough.
    "remoteUser": "analyst"
}
